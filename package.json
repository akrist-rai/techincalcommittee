{
  "name": "committee-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vercel dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "db:studio": "dotenv -e .env -- drizzle-kit studio",
    "db:seed": "dotenv -e .env -- tsx scripts/seed.ts",
    "db:reset-content": "dotenv -e .env -- tsx scripts/reset-content.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^3.0.3",
    "cookie": "^0.7.2",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.26",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "vercel": "^56.3.1",
    "vite": "^8.0.14"
  }
}
