# Copy this file to .env and fill in real values. Never commit .env.

# Neon Postgres connection string (use the pooled connection string from your
# Neon project dashboard — "Connect" -> "Pooled connection").
DATABASE_URL=postgres://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require

# Vercel Blob read/write token (Vercel project -> Storage -> Blob -> create
# a store -> copy the .env.local snippet it gives you).
BLOB_READ_WRITE_TOKEN=

# Used once by `npm run db:seed` to create the first admin login.
# Pick your own values before running the seed script.
ADMIN_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-before-seeding
